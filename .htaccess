# ── Security Headers ──
<IfModule mod_headers.c>
  Header always set X-Frame-Options "DENY"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── Force HTTPS ──
<IfModule mod_rewrite.c>
  RewriteEngine On

  # www to non-www redirect
  RewriteCond %{HTTP_HOST} ^www\.academiqr\.com [NC]
  RewriteRule ^(.*)$ https://academiqr.com/$1 [R=301,L]

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ── Cache Control ──
<IfModule mod_expires.c>
  ExpiresActive On
  # CSS/JS with hashed filenames — cache aggressively
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  # Images
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  # HTML — don't cache (so updates are seen immediately)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ── Prevent directory listing ──
Options -Indexes

# ── Block access to sensitive files ──
<FilesMatch "\.(env|gitignore|md|json|lock)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>
