# AcademiQR v1.0 — Apache Rewrite Rules

# Custom 404 page
ErrorDocument 404 /404.html

RewriteEngine On

# Social media crawlers → og.php (serves OG meta tags server-side)
RewriteCond %{HTTP_USER_AGENT} facebookexternalhit|Twitterbot|LinkedInBot|Slackbot|Discordbot|WhatsApp|TelegramBot [NC]
RewriteRule ^u/([^/]+)/([^/]+)/?$ /og.php [L,QSA]

# Short URLs for regular browsers: /u/username/slug → public.html
RewriteRule ^u/([^/]+)/([^/]+)/?$ /public.html [L,QSA]
